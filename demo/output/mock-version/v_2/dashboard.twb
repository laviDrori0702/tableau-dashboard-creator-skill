      <column caption='Total Revenue' datatype='real' name='[Calculation_100000000000000001]' role='measure' type='quantitative' default-format='$#,##0'>
        <calculation class='tableau' formula='SUM([revenue])' />
      </column>
      <column caption='Total Revenue Target' datatype='real' name='[Calculation_100000000000000002]' role='measure' type='quantitative' default-format='$#,##0'>
        <calculation class='tableau' formula='SUM([revenue_target])' />
      </column>
      <column caption='Revenue % of Target' datatype='real' name='[Calculation_100000000000000003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / SUM([revenue_target]) * 100' />
      </column>
      <column caption='Revenue Target Delta' datatype='string' name='[Calculation_100000000000000004]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF SUM([revenue]) / SUM([revenue_target]) * 100 &gt;= 100 THEN &quot;&#x25B2;&quot; ELSE &quot;&#x25BC;&quot; END + &quot; &quot; + STR(ROUND(SUM([revenue]) / SUM([revenue_target]) * 100, 1)) + &quot;% of target&quot;' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_100000000000000005]' role='measure' type='quantitative' default-format='$#,##0'>
        <calculation class='tableau' formula='SUM([profit])' />
      </column>
      <column caption='Profit Margin %' datatype='real' name='[Calculation_100000000000000006]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([revenue]) * 100' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_100000000000000007]' role='measure' type='quantitative' default-format='#,##0'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Total Orders Target' datatype='integer' name='[Calculation_100000000000000008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([orders_target])' />
      </column>
      <column caption='Orders % of Target' datatype='real' name='[Calculation_100000000000000009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id]) / SUM([orders_target]) * 100' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_100000000000000010]' role='measure' type='quantitative' default-format='$#,##0.00'>
        <calculation class='tableau' formula='SUM([revenue]) / COUNTD([order_id])' />
      </column>
      <column caption='Below Target Flag' datatype='string' name='[Calculation_100000000000000011]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF SUM([revenue]) &lt; SUM([revenue_target]) THEN &quot;Below&quot; ELSE &quot;On Track&quot; END' />
      </column>
