      <aliases enabled='yes' />
      <column caption='Color Expirations Delta' datatype='string' name='[COLORING New Business Delta (copy)_2494149810563178509]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// INVERTED direction: fewer expirations = good, more = bad.&#13;&#10;IF [Calculation_2494149810563112972] &lt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF [Calculation_2494149810563112972] = 0 THEN &apos;zero&apos;&#13;&#10;ELSE &apos;bad&apos; END&#13;&#10;// Map: &apos;good&apos; → #079455, &apos;bad&apos; → #D92D20' />
      </column>
      <column caption='Favorite Packages' datatype='boolean' name='[Calculation_2494149810525011968]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[package_group_name] in (&apos;Buyer&apos;, &apos;Dealer&apos;)' />
      </column>
      <column caption='Country Bucket' datatype='string' name='[Calculation_2494149810525151233]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [country_name] = &apos;India&apos; THEN &apos;India&apos;&#13;&#10;ELSEIF [country_name] = &apos;United States&apos; THEN &apos;United States&apos;&#13;&#10;ELSE &apos;ROW&apos;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;United States&quot;' value='US' />
        </aliases>
      </column>
      <column caption='Reference Date' datatype='date' name='[Calculation_2494149810557730818]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED: MAX([norm_date])}' />
      </column>
      <column caption='KPI Active Delta' datatype='real' name='[Calculation_2494149810557845507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Compare current reference date sc_cnt vs same-day last month.&#13;&#10;// E.g., Feb 21 sc_cnt vs Jan 21 sc_cnt.&#13;&#10;&#13;&#10;(&#13;&#10;  ZN({FIXED : SUM(IF [norm_date] = [Calculation_2494149810557730818] THEN [num_contracts] END)})&#13;&#10;  -&#13;&#10;  ZN({FIXED : SUM(IF [norm_date] = DATEADD(&apos;month&apos;, -1, [Calculation_2494149810557730818]) THEN [num_contracts] END)})&#13;&#10;)&#13;&#10;/&#13;&#10;ZN({FIXED : SUM(IF [norm_date] = DATEADD(&apos;month&apos;, -1, [Calculation_2494149810557730818]) THEN [num_contracts] END)})' />
      </column>
      <column caption='ColorTotal Contracts' datatype='string' name='[Calculation_2494149810558902277]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2494149810557845507] &gt; 0 THEN &quot;Good&quot;&#13;&#10;ELSE &quot;Bad&quot;&#13;&#10;END' />
      </column>
      <column caption='MTD New Business' datatype='integer' name='[Calculation_2494149810559692806]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Sum of new business contracts from month start to reference date.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818])&#13;&#10;     AND [norm_date] &lt;= [Calculation_2494149810557730818]&#13;&#10;  THEN ZN([new_business])&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI New Business Delta' datatype='real' name='[Calculation_2494149810559946759]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN([Calculation_2494149810559692806]) - ZN([Calculation_2494149810560045064])) / ZN([Calculation_2494149810560045064])' />
      </column>
      <column caption='Prior MTD New Business' datatype='integer' name='[Calculation_2494149810560045064]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Same day-count in prior month.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;month&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;month&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN ZN([new_business])&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='MTD Expirations' datatype='integer' name='[Calculation_2494149810562654218]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Sum of expirations from month start to reference date.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818])&#13;&#10;     AND [norm_date] &lt;= [Calculation_2494149810557730818]&#13;&#10;  THEN [expirations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='Prior MTD Expirations' datatype='integer' name='[Calculation_2494149810563022859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Same day-count window in prior month.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;month&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;month&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN [expirations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI Expirations Delta' datatype='real' name='[Calculation_2494149810563112972]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Percentage change: current MTD vs same MTD last month.&#13;&#10;&#13;&#10;([Calculation_2494149810562654218] - [Calculation_2494149810563022859]) / [Calculation_2494149810563022859]' />
      </column>
      <column caption='MTD Cancellations' datatype='integer' name='[Calculation_2494149810572533774]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Sum of cancellations from month start to reference date.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818])&#13;&#10;     AND [norm_date] &lt;= [Calculation_2494149810557730818]&#13;&#10;  THEN [canellations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='Prior MTD Cancellations' datatype='integer' name='[Calculation_2494149810572812303]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Same day-count window in prior month.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;month&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;month&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN [canellations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI Cancellations Delta' datatype='real' name='[Calculation_2494149810572935184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Percentage change: current MTD vs same MTD last month.&#13;&#10;&#13;&#10;([Calculation_2494149810572533774] - [Calculation_2494149810572812303]) / [Calculation_2494149810572812303]' />
      </column>
      <column caption='Pass Package Group Toggle' datatype='boolean' name='[Calculation_2494149810621628434]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// TRUE when the row&apos;s package group matches the selected toggle,&#13;&#10;// OR when &quot;All&quot; is selected (no package group filtering).&#13;&#10;//&#13;&#10;// This field is placed on the Filters shelf of all trend sheets.&#13;&#10;// When the parameter changes, all trend sheets re-filter instantly.&#13;&#10;&#13;&#10;[Parameters].[Parameter 1] = &apos;All&apos;&#13;&#10;OR [package_group_name] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='DZV: Toggle Buyer Is Active' datatype='boolean' name='[Calculation_2494149810859855894]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Returns TRUE when this toggle button should appear &quot;selected&quot;&#13;&#10;&#13;&#10;[Parameters].[Parameter 1] = &apos;Buyer&apos;' />
      </column>
      <column caption='DZV: Buyer' datatype='string' name='[Calculation_2494149810864410648]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Buyer&quot;' />
      </column>
      <column caption='Is Last 8 Weeks' datatype='boolean' name='[Calculation_2494149810918301738]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// V3: Excludes the current partial week.&#13;&#10;// Shows 8 COMPLETE weeks: from W-8 up to (but not including) the current week.&#13;&#10;//&#13;&#10;// Example: if Reference Date = Wednesday Feb 18, 2026&#13;&#10;//   Current week starts Mon Feb 16 → excluded&#13;&#10;//   Window: Mon Dec 22, 2025 through Sun Feb 15, 2026 (8 full weeks)&#13;&#10;&#13;&#10;DATETRUNC(&apos;week&apos;, [norm_date]) &gt;= DATEADD(&apos;week&apos;, -8, DATETRUNC(&apos;week&apos;, [Calculation_2494149810557730818]))&#13;&#10;AND DATETRUNC(&apos;week&apos;, [norm_date]) &lt; DATETRUNC(&apos;week&apos;, [Calculation_2494149810557730818])' />
      </column>
      <column caption='Week Label' datatype='string' name='[Calculation_2494149810918748203]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// V3: Adjusted offset to match the shifted window.&#13;&#10;// W1 = oldest complete week, W8 = most recent complete week.&#13;&#10;&#13;&#10;&apos;W&apos; + STR(&#13;&#10;  DATEDIFF(&#13;&#10;    &apos;week&apos;,&#13;&#10;    DATEADD(&apos;week&apos;, -8, DATETRUNC(&apos;week&apos;, [Calculation_2494149810557730818])),&#13;&#10;    DATETRUNC(&apos;week&apos;, [norm_date])&#13;&#10;  ) + 1&#13;&#10;)' />
      </column>
      <column caption='TRUE' datatype='boolean' name='[Calculation_2494149810927980595]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='TRUE' />
      </column>
      <column caption='FALSE' datatype='boolean' name='[Calculation_2494149810928013364]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='FALSE' />
      </column>
      <column caption='KPI Active YoY Delta' datatype='real' name='[Calculation_2494149810939793467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Compare current reference date sc_cnt vs same-day last year.&#13;&#10;(&#13;&#10;  {FIXED : SUM(IF [norm_date] = [Calculation_2494149810557730818] THEN [num_contracts] END)}&#13;&#10;  -&#13;&#10;  {FIXED : SUM(IF [norm_date] = DATEADD(&apos;year&apos;, -1, [Calculation_2494149810557730818]) THEN [num_contracts] END)}&#13;&#10;)&#13;&#10;/&#13;&#10;{FIXED : SUM(IF [norm_date] = DATEADD(&apos;year&apos;, -1, [Calculation_2494149810557730818]) THEN [num_contracts] END)}' />
      </column>
      <column caption='Color Active YoY Delta' datatype='string' name='[Calculation_2494149810940080188]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2494149810939793467] &gt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF [Calculation_2494149810939793467] = 0 then &apos;zero&apos;&#13;&#10;ELSE &apos;bad&apos; END' />
      </column>
      <column caption='Prior Year MTD New Business' datatype='integer' name='[Calculation_2494149810940350525]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Same day-count window in the prior YEAR&apos;s same month.&#13;&#10;// E.g., if reference = Feb 21, 2026, this sums Feb 1-21, 2025.&#13;&#10;&#13;&#10;SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;year&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;year&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN [new_business]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI New Business YoY Delta' datatype='real' name='[Calculation_2494149810940481598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Percentage change: current MTD vs same MTD last year.&#13;&#10;&#13;&#10;([Calculation_2494149810559692806] - [Calculation_2494149810940350525]) / [Calculation_2494149810940350525]' />
      </column>
      <column caption='Color New Business YoY Delta' datatype='string' name='[Calculation_2494149810940583999]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// Standard direction: more new business = good.&#13;&#10;IF [Calculation_2494149810940481598] &gt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF ZN([Calculation_2494149810940481598]) = 0 THEN &apos;zero&apos;&#13;&#10;&#13;&#10;ELSE &apos;bad&apos; END' />
      </column>
      <column caption='Prior Year MTD Expirations' datatype='integer' name='[Calculation_2494149810940670016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;year&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;year&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN [expirations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI Expirations YoY Delta' datatype='real' name='[Calculation_2494149810940743745]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2494149810562654218] - [Calculation_2494149810940670016]) / [Calculation_2494149810940670016]' />
      </column>
      <column caption='Color Expirations YoY Delta' datatype='string' name='[Calculation_2494149810940801090]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// INVERTED: fewer expirations = good, more = bad.&#13;&#10;IF [Calculation_2494149810940743745] &lt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF ZN([Calculation_2494149810940743745]) = 0 THEN &apos;zero&apos;&#13;&#10;ELSE &apos;bad&apos; END' />
      </column>
      <column caption='Prior Year MTD Cancellations' datatype='integer' name='[Calculation_2494149810940895299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;  IF [norm_date] &gt;= DATEADD(&apos;year&apos;, -1, DATETRUNC(&apos;month&apos;, [Calculation_2494149810557730818]))&#13;&#10;     AND [norm_date] &lt;= DATEADD(&apos;year&apos;, -1, [Calculation_2494149810557730818])&#13;&#10;  THEN [canellations]&#13;&#10;  END&#13;&#10;)' />
      </column>
      <column caption='KPI Cancellations YoY Delta' datatype='real' name='[Calculation_2494149810940952644]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN([Calculation_2494149810572533774]) - ZN([Calculation_2494149810940895299])) / ZN([Calculation_2494149810940895299])' />
      </column>
      <column caption='Color Cancellations YoY Delta' datatype='string' name='[Calculation_2494149810941026373]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// INVERTED: fewer cancellations = good, more = bad.&#13;&#10;IF [Calculation_2494149810940952644] &lt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF ZN([Calculation_2494149810940952644]) = 0 THEN &apos;zero&apos;&#13;&#10;ELSE &apos;bad&apos; END' />
      </column>
      <column aggregation='Sum' caption='Country Tier Size' datatype='integer' name='[Calculation_2494149810954891334]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Tier 1 (top 3): thickest lines&#13;&#10;// Tier 2 (mid 4): medium lines&#13;&#10;// Tier 3 (bottom 4): thin lines&#13;&#10;&#13;&#10;IF [country_name] IN (&apos;United States&apos;, &apos;India&apos;, &apos;Israel&apos;)&#13;&#10;  THEN 3&#13;&#10;ELSEIF [country_name] IN (&apos;Belgium&apos;, &apos;Hong Kong&apos;, &apos;Thailand&apos;, &apos;UAE&apos;)&#13;&#10;  THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='WeekEnd Total Contracts' datatype='integer' name='[Calculation_2494149810962772040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Returns Sc Cnt ONLY on the last day of each ISO week.&#13;&#10;// All other days within the week return NULL.&#13;&#10;// Use SUM([Week End Sc Cnt]) on Rows instead of SUM([Sc Cnt])&#13;&#10;// for the Active Contracts trend sheets.&#13;&#10;&#13;&#10;IF [norm_date] = { FIXED DATETRUNC(&apos;week&apos;, [norm_date]) : MAX([norm_date]) }&#13;&#10;THEN [num_contracts]&#13;&#10;END' />
      </column>
      <column caption='Last Datapoint' datatype='boolean' name='[Calculation_2494149810963894345]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[norm_date] = [Calculation_2494149810557730818]' />
      </column>
      <column caption='Color Cancellations Delta' datatype='string' name='[Color Expirations Delta (copy)_2494149810573058065]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// INVERTED direction: fewer cancellations = good, more = bad.&#13;&#10;IF [Calculation_2494149810572935184] &lt;= 0 THEN &apos;good&apos; &#13;&#10;ELSEIF zn([Calculation_2494149810572935184]) = 0 then &apos;zero&apos;&#13;&#10;ELSE &apos;bad&apos; END&#13;&#10;// Map: &apos;good&apos; → #079455, &apos;bad&apos; → #D92D20' />
      </column>
      <column aggregation='Sum' caption='Country Tier Size circles' datatype='integer' name='[Country Tier Size (copy)_2494149810955771975]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Tier 1 (top 3): thickest circles&#13;&#10;// Tier 2 (mid 4): medium circles&#13;&#10;// Tier 3 (bottom 4): thin circles&#13;&#10;&#13;&#10;IF [country_name] IN (&apos;United States&apos;, &apos;India&apos;, &apos;Israel&apos;)&#13;&#10;  THEN 3&#13;&#10;ELSEIF [country_name] IN (&apos;Belgium&apos;, &apos;Hong Kong&apos;, &apos;Thailand&apos;, &apos;UAE&apos;)&#13;&#10;  THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='DZV: Dealer' datatype='string' name='[DZV: Buyer (copy)_2494149810864492569]' role='dimension' type='nominal'>
