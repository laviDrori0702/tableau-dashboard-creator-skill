      <column caption='DZV: Toggle All Is not Active' datatype='boolean' name='[DZV: Toggle All Is Active (copy)_2494149810926518319]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Returns FALSE when this toggle button should appear &quot;selected&quot;&#13;&#10;&#13;&#10;[Parameters].[Parameter 1] != &apos;All&apos;' />
