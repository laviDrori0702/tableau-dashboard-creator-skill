    <datasource caption='subscriptionWaterfall' inline='true' name='federated.17m1p8r1b52vl813dyg0i1jz887h' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='tableau-prod1.cluster-cmj5ruislc3c.us-east-1.rds.amazonaws.com' name='postgres.0h1ljdq0zmqqwy18bzvjh11mz5bg'>
            <connection authentication='username-password' class='postgres' dbname='kinneret' one-time-sql='' port='5432' server='tableau-prod1.cluster-cmj5ruislc3c.us-east-1.rds.amazonaws.com' server-oauth='' username='lavid' workgroup-auth-mode='prompt' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0h1ljdq0zmqqwy18bzvjh11mz5bg' name='Custom SQL Query' type='text'><![CDATA[WITH
accounts_junk AS (
SELECT
id
FROM
kinneret.dim_accounts da
WHERE
"name" ILIKE '%apaport%' OR
("name" ILIKE '%test%' and "name" not ILIKE '%hitestone%')or ("name" ILIKE '%rap%' and "name" ILIKE '%qa%')
OR (
da.ofc_account_number IN (
83922, 83923, 89559, 75416, 70053, 75416, 55858, 55859, 62146, 62147, 62148, 79012, 79013, 80267, 80339, 80934, 80935, 125753
)
)
),
cancelled_contracts AS (
SELECT
dsc.id,
MAX(ssp.cancelled_date) AS cancelled_date,
COUNT(*) AS cnt
FROM
kinneret.sc_subscriptions_plans ssp
INNER JOIN kinneret.dim_opportunities t ON
t.id = ssp.opportunity_id
INNER JOIN kinneret.dim_subscriptions_contracts dsc ON
dsc.id = t.subscriptions_contract_id
AND dsc.end_date = ssp.cancelled_date
WHERE
ssp.cancelled_date IS NOT NULL
GROUP BY
1
),
o_freq AS (
SELECT
DISTINCT
ssp.opportunity_id,
ssp.payment_frequency
FROM
kinneret.sc_subscriptions_plans ssp
WHERE
ssp.start_date >>= '2024-01-01'
)
SELECT
dnd.norm_date::date AS norm_date,
pg."name" AS package_group_name,
CASE
WHEN (dsp.id IN (7, 13, 3)) THEN dsp."name"
ELSE 'Other'
END AS package_name,
CASE
WHEN (dc.id IN (248, 247, 245, 246, 81, 251, 45, 250, 14, 244, 215)) THEN dc."name"
ELSE 'Other'
END AS country_name,
du.service_office,
ofr.payment_frequency,
SUM(CASE
WHEN (sc.start_date = dnd.norm_date) THEN 1 ELSE 0
END) AS total_in,
SUM(CASE
WHEN (sc.start_date = dnd.norm_date AND o."type" = 'New Business') THEN 1 ELSE 0
END) AS new_business,
SUM(CASE
WHEN (sc.start_date = dnd.norm_date AND o."type" IN ('Renewal', 'Upgrade', 'Downgrade', 'Upgrade/Downgrade')) THEN 1 ELSE 0
END) AS upgrades_downgrades,
SUM(CASE
WHEN (sc.start_date = dnd.norm_date AND o."type" = 'In Trial') THEN 1 ELSE 0
END) AS in_trial,
SUM(CASE
WHEN (sc.end_date != dnd.norm_date AND sc.start_date != dnd.norm_date) THEN 1 ELSE 0
END) AS were_and_remaining,
SUM(CASE
WHEN (sc.end_date = dnd.norm_date) THEN 1 ELSE 0
END) AS total_out,
SUM(CASE
WHEN (sc.end_date = dnd.norm_date AND cc.id IS NULL) THEN 1 ELSE 0
END) AS expirations,
SUM(CASE
WHEN (sc.end_date = dnd.norm_date AND cc.id IS NOT NULL) THEN 1 ELSE 0
END) AS canellations,
COUNT(sc.id) AS num_contracts,
SUM(o.amount) AS opportunity_amount,
COUNT(DISTINCT sc.account_id) AS distinct_accounts
FROM
kinneret.dim_norm_dates dnd
INNER JOIN kinneret.dim_subscriptions_contracts sc ON
sc.start_date <<= dnd.norm_date
AND dnd.norm_date <<= sc.end_date
LEFT JOIN accounts_junk aj ON
aj.id = sc.account_id
LEFT JOIN cancelled_contracts cc ON
cc.id = sc.id
AND cc.cancelled_date = dnd.norm_date
LEFT JOIN kinneret.dim_opportunities o ON
o.subscriptions_contract_id = sc.id
AND o.created_date::date <<= sc.start_date
AND o.created_date >>= sc.start_date - INTERVAL '1 month'
AND o.stage_name = 'Closed Won'
AND o."type" != 'Add-on'
LEFT JOIN o_freq ofr ON
ofr.opportunity_id = o.id
LEFT JOIN kinneret.dim_subscriptions_packages dsp ON
dsp.id = sc.subscriptions_package_id
LEFT JOIN kinneret.dim_subscriptions_packages_groups pg ON
pg.id = dsp.dim_subscriptions_packages_groups_id
LEFT JOIN kinneret.dim_accounts da ON
da.id = sc.account_id
LEFT JOIN kinneret.dim_countries dc ON
dc.id = da.country_id
LEFT JOIN kinneret.dim_users du ON
du.id = da.sales_owner_id
WHERE
1=1
AND dnd.norm_date >>= '2025-01-01'
AND dnd.norm_date <<= CURRENT_DATE
AND aj.id IS NULL
GROUP BY
1,2,3,4,5,6
ORDER BY
1 ASC -- 5868132 18177]]></relation>
