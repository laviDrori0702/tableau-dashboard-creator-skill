            <column-instance column='[country_name]' derivation='None' name='[none:country_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[package_group_name]' derivation='None' name='[none:package_group_name:nk]' pivot='key' type='nominal' />
            <column caption='Norm Date' datatype='date' name='[norm_date]' role='dimension' type='ordinal' />
            <column caption='Total Contracts' datatype='integer' name='[num_contracts]' role='measure' type='quantitative' />
            <column caption='Package Group Name' datatype='string' name='[package_group_name]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2958020574306639878]' derivation='User' name='[usr:Calculation_2958020574306639878:qk]' pivot='key' type='quantitative' />
