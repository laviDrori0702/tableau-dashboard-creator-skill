            <column-instance column='[Calculation_2494149810941026373]' derivation='User' name='[usr:Calculation_2494149810941026373:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2958020574306586629]' derivation='User' name='[usr:Calculation_2958020574306586629:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
