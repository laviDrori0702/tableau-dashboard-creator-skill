            <column-instance column='[package_group_name]' derivation='None' name='[none:package_group_name:nk]' pivot='key' type='nominal' />
            <column caption='Norm Date' datatype='date' name='[norm_date]' role='dimension' type='ordinal' />
            <column caption='Total Contracts' datatype='integer' name='[num_contracts]' role='measure' type='quantitative' />
